[sub_resource type="GDScript" id="GDScript_wxdwa"]
script/source = "extends CanvasLayer

@onready var _texRect:TextureRect = $Control/TextureRect;
@export var _noiseTexture:TextureRect;


func _ready() -> void:
	_texRect.size = _noiseTexture.texture.get_size() * World.CellSize;
	#set_deferred(\"_texRect:size\", _noiseTexture.texture.get_size() * World.CellSize);
	#_texRect.size = _noiseTexture.size;
	#
	#_texRect.modulate.a = 0;
	#self.show();
	#
	#var cloudTween:Tween = create_tween();
	#cloudTween.set_trans(Tween.TRANS_SINE);
	#cloudTween.set_ease(Tween.EASE_IN_OUT);
	#cloudTween.tween_property(_texRect, \"modulate:a\", .5, 4);
#
#
func _process(delta: float) -> void:
	_texRect.texture.noise.offset.x -= delta * 4;
"

