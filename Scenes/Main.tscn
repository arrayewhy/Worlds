[sub_resource type="GDScript" id="GDScript_h1m7h"]
resource_name = "cancel"
script/source = "extends Sprite2D

var _mouseover:bool;

var _hover_tween:Tween;


func _ready() -> void:
	$Area2D.mouse_entered.connect(_Mouse_On);
	$Area2D.mouse_exited.connect(_Mouse_Off);


func _input(event: InputEvent) -> void:
	if event.is_action_pressed(\"Left-Click\") && _mouseover:
		$\"../../Curtain\".Obscure();
		await $\"../../Curtain\".Fade_Complete;
		get_tree().quit();


func _Mouse_On() -> void:
	_mouseover = true;
	
	if _hover_tween != null && _hover_tween.is_running():
		_hover_tween.kill();
		
	_hover_tween = create_tween();
	_hover_tween.set_trans(Tween.TRANS_CUBIC);
	_hover_tween.set_ease(Tween.EASE_IN_OUT);
	_hover_tween.tween_property(self, \"rotation_degrees\", 90, .5);

func _Mouse_Off() -> void:
	_mouseover = false;
	
	if _hover_tween != null && _hover_tween.is_running():
		_hover_tween.kill();
	
	_hover_tween = create_tween();
	_hover_tween.set_trans(Tween.TRANS_CUBIC);
	_hover_tween.set_ease(Tween.EASE_IN_OUT);
	_hover_tween.tween_property(self, \"rotation_degrees\", 0, .5);
"

