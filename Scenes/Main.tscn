[sub_resource type="GDScript" id="GDScript_2w5on"]
resource_name = "Cursor Rotater"
script/source = "extends Sprite2D

var _active:bool;


func _process(delta: float) -> void:
	if Input.is_action_pressed(\"Left\") || Input.is_action_pressed(\"Up\"):
		self.rotate(-4 * delta);
	elif Input.is_action_pressed(\"Right\") || Input.is_action_pressed(\"Down\"):
		self.rotate(4 * delta);
	pass;
"

